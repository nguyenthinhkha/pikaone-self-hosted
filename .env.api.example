PORT=4000
DATABASE_URL="postgresql://pika:change-me@db:5432/pikaonedb?schema=public"
JWT_SECRET=change-me
JWT_ACCESS_TOKEN_EXPIRES_IN="7d"
JWT_REFRESH_TOKEN_EXPIRES_IN_DAYS=30
PASSWORD_RESET_TOKEN_EXPIRES_IN_HOURS=1
RESEND_API_KEY=
RESEND_FROM_EMAIL=
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=
WEB_BASE_URL=http://localhost:3000

# First administrator (required on first boot; seed runs after migrations on API start)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini

# Application-level encryption (AES-256-GCM per-user DEK wrapped by MASTER_KEY)
# Generate: openssl rand -base64 32
MASTER_KEY=
ENCRYPTION_ENABLED=false
ENCRYPTION_DEK_CACHE_TTL_SECONDS=1800
# Rollout on existing data: 1) set MASTER_KEY  2) run encrypt script (see README)
# 3) ENCRYPTION_ENABLED=true + restart API

# Logging
LOG_LEVEL=info
LOG_PRETTY=false

# OpenTelemetry — enable when observability stack is running
# OTEL_SERVICE_NAME=pikaone-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=self-hosted

# Asset prices (optional scheduler overrides)
# ASSET_PRICES_TIMEZONE=Asia/Ho_Chi_Minh
# ASSET_PRICES_VN_STOCKS_CRON=0 16 * * *
# ASSET_PRICES_US_MARKET_CRON=0 6 * * *
# ASSET_PRICES_SJC_CRON=0 18 * * *
# ASSET_PRICES_CRYPTO_CRON=0 * * * *

# Chat / MCP
# CHAT_LLM_PROVIDER=openai
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b
